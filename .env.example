# android-tab-harvest 設定テンプレ。
# 使い方:
#   cp .env.example .env
# .env は .gitignore 対象。個人情報（端末シリアル等）はここではなく .env に書く。

# 対象端末のADBシリアル（複数端末がある場合の絞り込み・メモ用途）
ADB_SERIAL=

# 端末モデル名（メモ用）
ADB_DEVICE_MODEL=

# Chrome DevToolsポートフォワードの先頭ポート（複数端末は順に+1される）
COLLECTOR_BASE_PORT=9222

# (将来) LM Studio 要約API
# LM_STUDIO_URL=http://localhost:1234/v1/chat/completions

# (将来) Google Drive バックアップ先（rclone リモート名）
# RCLONE_REMOTE=gdrive:tab-manager/
